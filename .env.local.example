# =============================================
# Supabase 설정 (필수)
# Supabase 프로젝트 생성 후 Project Settings > API 에서 확인
# =============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key (서버 전용 - 절대 클라이언트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================
# 관리자 설정
# Supabase Auth에 직접 등록하는 방식을 사용하므로
# 아래는 참고용 주석 (실제 계정은 Supabase Auth에서 생성)
# =============================================
# 관리자 계정: dkdl137900 / 9004okok!!
# → Supabase Dashboard > Authentication > Users > Add User 에서 직접 등록

# =============================================
# 사이트 설정
# =============================================
NEXT_PUBLIC_SITE_URL=https://cardlab.digital

# =============================================
# 관리자 라우트 보호용 시크릿 (선택)
# =============================================
ADMIN_SECRET=your-random-secret-string-here
